mtf1_bear  = input.color(color.new(color.red,   80), "", inline = "m1", group = "Multi-TF FVG Display")

mtf2_show  = input.bool(false, "TF #2", inline = "m2",  group = "Multi-TF FVG Display")
mtf2_tf    = input.timeframe("240","", inline = "m2",   group = "Multi-TF FVG Display")
mtf2_lbl   = input.string("4h", "",    inline = "m2",   group = "Multi-TF FVG Display")
