mtf3_lbl   = input.string("D",  "",    inline = "m3",   group = "Multi-TF FVG Display")
mtf3_bull  = input.color(color.new(color.green, 80), "", inline = "m3", group = "Multi-TF FVG Display")
mtf3_bear  = input.color(color.new(color.red,   80), "", inline = "m3", group = "Multi-TF FVG Display")

mtf_border_w     = input.int(1, "Border Width", minval = 0, maxval = 3, group = "Multi-TF FVG Display")
mtf_bull_border  = input.color(color.new(color.green, 100), "Bull Border", inline = "br", group = "Multi-TF FVG Display")
mtf_bear_border  = input.color(color.new(color.red,   100), "Bear Border", inline = "br", group = "Multi-TF FVG Display")
mtf_show_mid     = input.bool(false, "Show Midline", inline = "mid", group = "Multi-TF FVG Display")
mtf_bull_mid     = input.color(color.new(color.green, 0), "Bull", inline = "mid", group = "Multi-TF FVG Display")
mtf_bear_mid     = input.color(color.new(color.red,   0), "Bear", inline = "mid", group = "Multi-TF FVG Display")
mtf_lbl_size_in  = input.string("Tiny",  "Label Size",  options = ["Tiny", "Small", "Normal", "Large"], group = "Multi-TF FVG Display")
mtf_lbl_align_in = input.string("Right", "Label Align", options = ["Left", "Center", "Right"], group = "Multi-TF FVG Display")

// ============================================================================
// Inputs — Confluence (HTF + Local same bar)
// ============================================================================
conf_lbl_show   = input.bool(true, "Show Confluence Label", group = "Confluence (HTF + Local same bar)")
conf_lbl_color  = input.color(color.yellow,         "Confluence Label Color", group = "Confluence (HTF + Local same bar)")
conf_lbl_text   = input.color(color.new(#1e2230,0), "Confluence Text Color",  group = "Confluence (HTF + Local same bar)")
conf_lbl_suffix = input.string("★",                 "Confluence Label Suffix", group = "Confluence (HTF + Local same bar)")
conf_use_tf1    = input.bool(true,  "Use TF #1", inline = "cuse", group = "Confluence (HTF + Local same bar)")
conf_use_tf2    = input.bool(true,  "Use TF #2", inline = "cuse", group = "Confluence (HTF + Local same bar)")
conf_use_tf3    = input.bool(true,  "Use TF #3", inline = "cuse", group = "Confluence (HTF + Local same bar)")

// ============================================================================
// Inputs — Re-test arrows
// ============================================================================
show_arrows = input.bool(true,  "Show Re-test Arrows", group = "Re-test Arrows")
fvg_a_bull  = input.color(color.green,   "FVG bull",  inline = "fvg_a",  group = "Re-test Arrows")
fvg_a_bear  = input.color(color.red,     "FVG bear",  inline = "fvg_a",  group = "Re-test Arrows")
og_a_bull   = input.color(color.lime,    "OG  bull",  inline = "og_a",   group = "Re-test Arrows")
og_a_bear   = input.color(color.maroon,  "OG  bear",  inline = "og_a",   group = "Re-test Arrows")
vi_a_bull   = input.color(color.aqua,    "VI  bull",  inline = "vi_a",   group = "Re-test Arrows")
vi_a_bear   = input.color(color.fuchsia, "VI  bear",  inline = "vi_a",   group = "Re-test Arrows")
ifvg_a_bull = input.color(color.olive,   "IFVG bull", inline = "ifvg_a", group = "Re-test Arrows")
ifvg_a_bear = input.color(color.purple,  "IFVG bear", inline = "ifvg_a", group = "Re-test Arrows")

// ============================================================================
// Helpers
// ============================================================================
n   = bar_index
atr = ta.atr(200)

imbalance_detection(show, usewidth, method, width, top, btm, condition) =>
    var bool is_width = true
    if usewidth
        dist = top - btm
        is_width := switch method
            "Points" => dist > width
            "%"      => dist / btm * 100 > width
            "ATR"    => dist > atr * width
    show and condition and is_width

// Push to active + history. When history exceeds max_show, delete oldest box/line
// AND remove its entry from active arrays (so process_zones doesn't touch a deleted object).
push_zone(array<float> tops, array<float> btms, array<line> lines, array<box> boxes, array<int> created,
          array<line> hist_lines, array<box> hist_boxes, array<int> hist_created,
          float top, float btm, line ln, box bx) =>
    array.push(tops, top)
    array.push(btms, btm)
    array.push(lines, ln)
    array.push(boxes, bx)
    array.push(created, n)
    array.push(hist_lines, ln)
    array.push(hist_boxes, bx)
    array.push(hist_created, n)

    while array.size(hist_lines) > max_show
        old_ln = array.shift(hist_lines)
        old_bx = array.shift(hist_boxes)
        old_cr = array.shift(hist_created)
        // Remove from active arrays if still present (match by creation bar_index)
        if array.size(created) > 0
            for i = array.size(created) - 1 to 0
                if array.get(created, i) == old_cr
                    array.remove(tops, i)
                    array.remove(btms, i)
                    array.remove(lines, i)
                    array.remove(boxes, i)
                    array.remove(created, i)
                    break
        if not na(old_ln)
            line.delete(old_ln)
        if not na(old_bx)
            box.delete(old_bx)

process_zones(array<float> tops, array<float> btms, array<line> lines, array<box> boxes, array<int> created, bool is_bullish,
              bool ifvg_on,
              array<float> ifvg_tops, array<float> ifvg_btms, array<line> ifvg_lines, array<box> ifvg_boxes, array<int> ifvg_created,
              array<line> ifvg_hist_lines, array<box> ifvg_hist_boxes, array<int> ifvg_hist_created, color ifvg_css) =>
    signal = false
    if array.size(tops) > 0
        for i = array.size(tops) - 1 to 0
            top = array.get(tops, i)
            btm = array.get(btms, i)
            ln  = array.get(lines, i)
            bx  = array.get(boxes, i)
            cr  = array.get(created, i)
            mid = math.avg(top, btm)

            if not na(ln)
                line.set_x2(ln, n)
            if not na(bx)
                box.set_right(bx, n)

            if use_autoclean and n - cr > autoclean_bars
                array.remove(tops, i)
                array.remove(btms, i)
                array.remove(lines, i)
                array.remove(boxes, i)
                array.remove(created, i)
                continue

            mitigated = is_bullish
              ? (mitig_mode == "Close" ? close < btm : low < btm)
              : (mitig_mode == "Close" ? close > top : high > top)

            if mitigated
                if ifvg_on
                    ibx = box.new(n, top, n, btm,
                      border_color = na,
                      bgcolor = color.new(ifvg_css, 70),
                      text = "iFVG", text_color = chart.fg_color)
                    push_zone(ifvg_tops, ifvg_btms, ifvg_lines, ifvg_boxes, ifvg_created,
                      ifvg_hist_lines, ifvg_hist_boxes, ifvg_hist_created, top, btm, na, ibx)
                array.remove(tops, i)
                array.remove(btms, i)
                array.remove(lines, i)
                array.remove(boxes, i)
                array.remove(created, i)
                continue

            entered = retest_mode == "CE (50%)"
              ? (is_bullish ? low <= mid : high >= mid)
              : (low <= top and high >= btm)

            if n > cr and entered
                signal := true
                array.remove(tops, i)
                array.remove(btms, i)
                array.remove(lines, i)
                array.remove(boxes, i)
                array.remove(created, i)
    signal

webhook_send(string side, string kind) =>
    arrow = side == "bull" ? "🔼" : "🔽"
    label = side == "bull" ? "LOW "  : "HIGH "
    alert(syminfo.ticker + " " + timeframe.period + arrow + label + kind + " Re-test",
      alert.freq_once_per_bar)

// Side-effect-free FVG re-test detector for use inside request.security().
// Tracks only the most recent unmitigated FVG per side via `var` scalars.
fvg_retest_simple(bool side_bull) =>
    var float ftop     = na
    var float fbtm     = na
    var bool  fretested = false
    fvg = side_bull ? (low > high[2] and close[1] > high[2]) : (high < low[2] and close[1] < low[2])
    if fvg
        ftop      := side_bull ? low     : low[2]
        fbtm      := side_bull ? high[2] : high
        fretested := false
    sig = false
    if not na(ftop)
        mit = side_bull ? low < fbtm : high > ftop
        if mit
            ftop := na
            fbtm := na
        else if not fretested and low <= ftop and high >= fbtm
            sig       := true
            fretested := true
    sig

// HTF FVG drawing — detects FVG on the bar 2 steps back (confirmed) on HTF data,
// draws a box on the LTF chart using bar_time coords, extends until mitigated.
mtf_label_size() =>
    switch mtf_lbl_size_in
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        => size.tiny

mtf_label_align() =>
    switch mtf_lbl_align_in
        "Left"   => text.align_left
        "Center" => text.align_center
        "Right"  => text.align_right
        => text.align_right

// boxes/mids hold drawn objects; tops/btms hold zone bounds (top > btm always);
// seen stores HTF open_time of the gap candle (t2) used for dedup & mitigation reference.
mtf_fvg_process(array<box> boxes, array<line> mids, array<float> tops, array<float> btms, array<bool> bulls, array<int> seen, bool show_tf, string htf_param, float h0, float l0, float h2, float l2, float c0, int t2, color bull_bg, color bear_bg, string lbl_text) =>
    tf_ok = not mtf_ltf_hide or timeframe.in_seconds() <= timeframe.in_seconds(htf_param)
    if show_tf and tf_ok and not na(h0) and not na(l0) and not na(h2) and not na(l2) and not na(t2) and not na(time[1])
        is_bull = l0 > h2
        is_bear = h0 < l2
        is_new  = array.size(seen) == 0
        if not is_new and (is_bull or is_bear)
            is_new := array.get(seen, array.size(seen) - 1) != t2
        if (is_bull or is_bear) and is_new
            top   = is_bull ? l0 : l2
            btm   = is_bull ? h2 : h0
            // Fixed right edge = creation time + extend CHART (LTF) bars forward.
            // Same visual width regardless of which HTF the FVG comes from.
            r_t = time + (time - time[1]) * mtf_disp_extend
            bx = box.new(t2, top, r_t, btm, xloc = xloc.bar_time,
                  border_color = is_bull ? mtf_bull_border : mtf_bear_border,
                  border_width = mtf_border_w,
                  bgcolor      = is_bull ? bull_bg : bear_bg,
                  text         = lbl_text,
                  text_color   = is_bull ? mtf_bull_mid : mtf_bear_mid,
                  text_halign  = mtf_label_align(),
                  text_size    = mtf_label_size())
            mid_v   = math.avg(top, btm)
            mid_col = is_bull ? mtf_bull_mid : mtf_bear_mid
            ml = mtf_show_mid ? line.new(t2, mid_v, r_t, mid_v, xloc = xloc.bar_time, style = line.style_dotted, color = mid_col) : na
            array.push(boxes, bx)
            array.push(mids,  ml)
            array.push(tops,  top)
            array.push(btms,  btm)
            array.push(bulls, is_bull)
            array.push(seen,  t2)
            if array.size(boxes) > mtf_max_count
                old_bx = array.shift(boxes)
                old_ml = array.shift(mids)
                array.shift(tops)
                array.shift(btms)
                array.shift(bulls)
                array.shift(seen)
                if not na(old_bx)
                    box.delete(old_bx)
                if not na(old_ml)
                    line.delete(old_ml)
    // Mitigate existing boxes (close-based, RunRox-style). Right edge is FIXED at creation
    // (creation_time + extend bars) — boxes do NOT keep extending forever as price advances.
    if array.size(boxes) > 0
        for i = array.size(boxes) - 1 to 0
            top_i  = array.get(tops, i)
            btm_i  = array.get(btms, i)
            is_bull_i = array.get(bulls, i)
            mitigated = is_bull_i ? close < btm_i : close > top_i
            bx = array.get(boxes, i)
            ml = array.get(mids,  i)
            if mitigated and mtf_remove_fill
                if not na(bx)
                    box.delete(bx)
                if not na(ml)
                    line.delete(ml)
                array.remove(boxes, i)
                array.remove(mids,  i)
                array.remove(tops,  i)
                array.remove(btms,  i)
                array.remove(bulls, i)
                array.remove(seen,  i)
            if mitigated and not mtf_remove_fill
                if not na(bx)
                    box.set_right(bx, time)
                if not na(ml)
                    line.set_x2(ml, time)
            int _drop = 0

// Consume all active HTF zones of the given side — used after a confluence fires
// so the same HTF zones don't trigger another label on subsequent re-tests.
mtf_consume_side(array<bool> bulls, array<float> tops, array<float> btms, array<box> boxes, array<line> mids, array<int> seen, bool want_bull) =>
    if array.size(bulls) > 0
        for i = array.size(bulls) - 1 to 0
            if array.get(bulls, i) == want_bull
                array.remove(boxes, i)
                array.remove(mids,  i)
                array.remove(tops,  i)
                array.remove(btms,  i)
                array.remove(bulls, i)
                array.remove(seen,  i)
            int _z = 0

// When the local LTF FVG is re-tested, freeze any overlapping HTF boxes at this bar
// (they coincided with the mitigated zone — extend should stop there).
mtf_freeze_overlap(array<box> boxes, array<line> mids, array<float> tops, array<float> btms, array<bool> bulls, array<int> seen, bool side_bull, float touch_price) =>
    if array.size(boxes) > 0
        for i = array.size(boxes) - 1 to 0
            if array.get(bulls, i) == side_bull
                top_i = array.get(tops, i)
                btm_i = array.get(btms, i)
                if touch_price >= btm_i and touch_price <= top_i
                    bx = array.get(boxes, i)
                    ml = array.get(mids, i)
                    if not na(bx)
                        box.set_right(bx, time)
                    if not na(ml)
                        line.set_x2(ml, time)
                    array.remove(boxes, i)
                    array.remove(mids,  i)
                    array.remove(tops,  i)
                    array.remove(btms,  i)
                    array.remove(bulls, i)
                    array.remove(seen,  i)
            int _d = 0

