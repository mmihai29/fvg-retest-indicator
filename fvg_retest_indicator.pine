//@version=5
indicator("FVG/OG/VI Re-test [Custom]", overlay = true,
  max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

// ============================================================================
// Inputs — Fair Value Gaps
// ============================================================================
show_fvg     = input.bool(true,  "Fair Value Gaps (FVG)", inline = "fvg_css", group = "Fair Value Gaps")
bull_fvg_css = input.color(#2157f3, "",                    inline = "fvg_css", group = "Fair Value Gaps")
bear_fvg_css = input.color(#ff1100, "",                    inline = "fvg_css", group = "Fair Value Gaps")
fvg_usewidth = input.bool(false, "Min Width",              inline = "fvg_w",   group = "Fair Value Gaps")
fvg_gapwidth = input.float(0,    "",                       inline = "fvg_w",   group = "Fair Value Gaps")
fvg_method   = input.string("Points", "", options = ["Points", "%", "ATR"], inline = "fvg_w", group = "Fair Value Gaps")
show_fvg_mid = input.bool(true,  "Show FVG Mid-Line",      group = "Fair Value Gaps")

// Liquidity sweep confluence (FVG only)
use_sweep      = input.bool(false, "Highlight FVG with Liquidity Sweep", inline = "sw", group = "Fair Value Gaps")
sweep_lookback = input.int(10,   "Lookback", minval = 2,                 inline = "sw", group = "Fair Value Gaps")

// ============================================================================
// Inputs — Opening Gaps
// ============================================================================
show_og     = input.bool(true,  "Opening Gaps (OG)",       inline = "og_css", group = "Opening Gaps")
bull_og_css = input.color(#2157f3, "",                     inline = "og_css", group = "Opening Gaps")
bear_og_css = input.color(#ff1100, "",                     inline = "og_css", group = "Opening Gaps")
og_usewidth = input.bool(false, "Min Width",               inline = "og_w",   group = "Opening Gaps")
og_gapwidth = input.float(0,    "",                        inline = "og_w",   group = "Opening Gaps")
og_method   = input.string("Points", "", options = ["Points", "%", "ATR"], inline = "og_w", group = "Opening Gaps")

// ============================================================================
// Inputs — Volume Imbalance
// ============================================================================
show_vi     = input.bool(true,  "Volume Imbalance (VI)",   inline = "vi_css", group = "Volume Imbalance")
bull_vi_css = input.color(#2157f3, "",                     inline = "vi_css", group = "Volume Imbalance")
bear_vi_css = input.color(#ff1100, "",                     inline = "vi_css", group = "Volume Imbalance")
vi_usewidth = input.bool(false, "Min Width",               inline = "vi_w",   group = "Volume Imbalance")
vi_gapwidth = input.float(0,    "",                        inline = "vi_w",   group = "Volume Imbalance")
vi_method   = input.string("Points", "", options = ["Points", "%", "ATR"], inline = "vi_w", group = "Volume Imbalance")

// ============================================================================
// Inputs — Inversion FVG (IFVG)
// ============================================================================
show_ifvg     = input.bool(false, "Show Inversion FVG (IFVG)", group = "Inversion FVG")
bull_ifvg_css = input.color(#089981, "Bull IFVG (was bear FVG)", inline = "ifvg_c", group = "Inversion FVG")
bear_ifvg_css = input.color(#f23645, "Bear IFVG (was bull FVG)", inline = "ifvg_c", group = "Inversion FVG")

// ============================================================================
// Inputs — Behavior
// ============================================================================
mitig_mode     = input.string("Wick",  "Mitigation Mode", options = ["Wick", "Close"],     group = "Behavior")
retest_mode    = input.string("Touch", "Re-test Mode",    options = ["Touch", "CE (50%)"], group = "Behavior")
use_autoclean  = input.bool(true,  "Auto-cleanup old zones", inline = "ac", group = "Behavior")
autoclean_bars = input.int(200,   "after N bars", minval = 10,             inline = "ac", group = "Behavior")
max_show       = input.int(20, "Max visible zones on chart (per type per side)", minval = 1, maxval = 200, group = "Behavior")

// ============================================================================
// Inputs — Multi-TF FVG Confluence (alerts)
// ============================================================================
use_mtf = input.bool(false, "Enable Multi-TF FVG Confluence", group = "Multi-TF FVG Confluence")
htf1    = input.timeframe("60",  "TF #1", inline = "tf", group = "Multi-TF FVG Confluence")
htf2    = input.timeframe("240", "TF #2", inline = "tf", group = "Multi-TF FVG Confluence")
htf3    = input.timeframe("D",   "TF #3", inline = "tf", group = "Multi-TF FVG Confluence")

// ============================================================================
// Inputs — Multi-TF FVG Display (chart visualization)
